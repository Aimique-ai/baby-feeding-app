{
  "extends": "@leon/typescript-config/react.json",
  "compilerOptions": {
    "types": ["node", "vite/client", "@react-router/node"],
    "paths": {
      "~/*": ["./app/*"]
    },
    "rootDirs": [".", "./.react-router/types"]
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    ".react-router/types/**/*",
    "*.config.ts"
  ]
}
