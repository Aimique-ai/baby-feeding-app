{
  "name": "@leon/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env.local src/server.ts",
    "build": "tsup",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "seed:formulas": "tsx --env-file=../../.env.local src/scripts/seed-formulas.ts",
    "backfill:baby-formula": "tsx --env-file=../../.env.local src/scripts/backfill-baby-formula.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.8.0",
    "@leon/domain": "workspace:*",
    "@leon/schemas": "workspace:*",
    "bullmq": "^5.78.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "hono": "^4.6.14",
    "ioredis": "^5.10.1",
    "mongoose": "^9.6.1",
    "tsx": "^4.21.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@leon/eslint-config": "workspace:*",
    "@leon/typescript-config": "workspace:*",
    "@types/node": "^20",
    "@types/web-push": "^3.6.4",
    "eslint": "^9.0.0",
    "tsup": "^8.3.5",
    "typescript": "^6"
  }
}
