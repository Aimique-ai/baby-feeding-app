# Build context for the root Dockerfile (context = repo root).
# Keep it lean: the Dockerfile copies only what it needs, and node_modules /
# build artifacts are regenerated inside the image.

# Dependencies & build outputs (reinstalled / rebuilt in-image)
**/node_modules
**/dist
**/build
**/.turbo
.turbo

# Other apps not in the server image (web is kept — built in-image)
apps/mobile

# Native mobile artifacts (can be gigabytes)
**/ios
**/android
**/.expo

# VCS & tooling
.git
.github
.vscode
.agents
.omc
.claude

# Local env & secrets — never bake into an image
.env
.env.*

fly.toml

# Docs, design, misc
docs
.design
README.md
**/*.md
**/.DS_Store
