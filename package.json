{
  "name": "leon-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "seed": "tsx --env-file=.env.local scripts/seed.ts",
    "seed:formulas": "tsx --env-file=.env.local scripts/seed-formulas.ts",
    "migrate:baby-id": "tsx --env-file=.env.local scripts/migrate-baby-id.ts",
    "migrate:drop-legacy-fields": "tsx --env-file=.env.local scripts/migrate-drop-legacy-fields.ts",
    "backfill:baby-formula": "tsx --env-file=.env.local scripts/backfill-baby-formula.ts",
    "worktree:new": "bash scripts/new-worktree.sh",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@leon/schemas": "workspace:*",
    "@leon/contracts": "workspace:*",
    "@leon/domain": "workspace:*",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.100.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "lucide-react": "^1.14.0",
    "mongoose": "^9.6.1",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.75.0",
    "recharts": "3.8.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "exceljs": "^4.4.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
